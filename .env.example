# Matrix サーバ設定
DATABASE_URL=mysql://matrix:changeme@127.0.0.1:13306/matrix
BIND_ADDR=0.0.0.0:8448
SERVER_NAME=localhost
# CORS許可オリジン（*=全許可、カンマ区切りで複数指定可）
CORS_ORIGINS=*

# ログレベル
RUST_LOG=server=debug,tower_http=debug

# DB接続
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=matrix
# アプリ用
DB_USER=matrix
DB_PASS=changeme
# MariaDB root（compose起動時のみ使用）
DB_ROOT_PASS=changeme
# スキーマ管理用（DDL権限が必要）
DB_SCHEMA_USER=matrix
DB_SCHEMA_PASS=changeme
