# Matrix サーバ設定
# このファイルを .env にコピーして各値を設定してください
# cp .env.example .env

BIND_ADDR=0.0.0.0:8448
SERVER_NAME=localhost
# CORS許可オリジン（*=全許可、カンマ区切りで複数指定可）
CORS_ORIGINS=*

# メディアファイルの保存先（デフォルト: ./media）
# MEDIA_PATH=./media

# メディアバックエンド（デフォルト: local）
# S3 を使う場合は --features server/s3 でビルドし、以下を設定する
# MEDIA_BACKEND=s3
# S3_BUCKET=<your-bucket-name>
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=<your-access-key>
# AWS_SECRET_ACCESS_KEY=<your-secret-key>
# MinIO 等の場合は以下も設定する
# AWS_ENDPOINT_URL=http://localhost:9000

# sqlx offline mode（CI など DB なし環境でのビルド用）
# query!() マクロを使う場合は cargo sqlx prepare で .sqlx/ を生成してから有効化
# SQLX_OFFLINE=true

# SSO / OAuth2（使用するプロバイダーの環境変数のみ設定すればよい）
# 全プロバイダー共通: コールバック URL（Matrix サーバーのアドレスで設定）
# SSO_REDIRECT_URI=https://your-server/_matrix/client/v3/login/sso/callback

# Google
# GOOGLE_CLIENT_ID=<your-google-client-id>
# GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# GitHub
# GITHUB_CLIENT_ID=<your-github-client-id>
# GITHUB_CLIENT_SECRET=<your-github-client-secret>

# Apple（Sign in with Apple）
# APPLE_CLIENT_ID=<your-apple-service-id>    例: com.example.daberiba
# APPLE_TEAM_ID=<your-team-id>               Apple Developer Team ID (10 文字)
# APPLE_KEY_ID=<your-key-id>                 Apple Developer の Key ID (10 文字)
# APPLE_PRIVATE_KEY=<pem-content>            .p8 ファイルの内容（改行は \n でエスケープ）

# ログレベル
RUST_LOG=server=debug,tower_http=debug

# DB接続（DATABASE_URL が未設定の場合は以下から自動構築）
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=matrix
DB_USER=matrix
DB_PASS=<your-password>
# MariaDB root（compose起動時のみ使用）
DB_ROOT_PASS=<your-root-password>
