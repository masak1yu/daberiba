# Matrix サーバ設定
DATABASE_URL=mysql://matrix:matrix@127.0.0.1:13306/matrix
BIND_ADDR=0.0.0.0:8448
SERVER_NAME=localhost

# ログレベル
RUST_LOG=server=debug,tower_http=debug

# schema/justfile 用
