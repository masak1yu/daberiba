{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(GIT_EDITOR=true git rebase --continue)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/pre-pr-check.sh",
            "timeout": 120,
            "statusMessage": "Running pre-PR checks (fmt, tests)..."
          }
        ]
      }
    ]
  }
}
